# ── Copy this file to .env and fill in your keys ──────────────────────────
# .env is gitignored — never commit secrets!

# Leonardo AI API key (get from cloud.leonardo.ai → Your Account → API)
LEONARDO_API_KEY=your_key_here

# Google OAuth client ID (already hardcoded as fallback — optional locally)
# GOOGLE_CLIENT_ID=256326772055-...

# Leader emails (format: email:Name,email2:Name2)
# LEADER_EMAILS=you@gmail.com:דני
